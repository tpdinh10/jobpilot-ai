# ===============================
# SERVER CONFIG
# ===============================
PORT=5000

# ===============================
# DATABASE (MongoDB Atlas)
# ===============================
# Example:
# mongodb+srv://username:password@cluster.mongodb.net/jobpilot
MONGO_URI=your_mongodb_connection_string

# ===============================
# AUTH (JWT)
# ===============================
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# ===============================
# AI CONFIG (OpenAI)
# ===============================
# Get your API key from OpenAI dashboard
OPENAI_API_KEY=your_openai_api_key

# ===============================
# OPTIONAL: AI FALLBACK MODE
# ===============================
# If true → use fallback instead of OpenAI
# If false → use OpenAI (recommended for production)
AI_FALLBACK=false